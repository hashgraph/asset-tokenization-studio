# ATS Smart Contracts - Environment Variables
#
# Copy this file to .env and fill in your values.
#
# IMPORTANT: Hardhat validates ALL private keys at startup, even for networks
# you're not targeting. Only uncomment the network(s) you plan to use.

# =============================================================================
# ACCOUNTS AND KEYS
# =============================================================================
# Private keys in RAW hex format (not DER encoded).
# KEY_0 is used as the deployer account. Additional keys are for test accounts.
# Uncomment ONLY the network(s) you need.

# Hardhat (in-memory test network) - uses Hardhat's built-in accounts
# No private keys needed for hardhat network

# Local (generic local Ethereum node)
# LOCAL_PRIVATE_KEY_0='your_private_key_here'
# LOCAL_PRIVATE_KEY_1='your_private_key_here'

# Hedera Local (Docker-based Hedera local node)
# HEDERA_LOCAL_PRIVATE_KEY_0='your_private_key_here'
# HEDERA_LOCAL_PRIVATE_KEY_1='your_private_key_here'

# Hedera Previewnet
# HEDERA_PREVIEWNET_PRIVATE_KEY_0='your_private_key_here'
# HEDERA_PREVIEWNET_PRIVATE_KEY_1='your_private_key_here'

# Hedera Testnet (uncomment to use)
# HEDERA_TESTNET_PRIVATE_KEY_0='your_private_key_here'
# HEDERA_TESTNET_PRIVATE_KEY_1='your_private_key_here'

# Hedera Mainnet (uncomment to use)
# HEDERA_MAINNET_PRIVATE_KEY_0='your_private_key_here'
# HEDERA_MAINNET_PRIVATE_KEY_1='your_private_key_here'

# =============================================================================
# NETWORK ENDPOINTS
# =============================================================================
# JSON-RPC endpoints for contract deployment and interaction.
# Mirror Node endpoints for querying historical data.
# Uncomment ONLY the network(s) you need.

# Local (generic local Ethereum node, defaults to http://127.0.0.1:8545)
# LOCAL_JSON_RPC_ENDPOINT='http://127.0.0.1:8545'

# Hedera Local (Docker-based Hedera local node)
# HEDERA_LOCAL_JSON_RPC_ENDPOINT='http://127.0.0.1:7546'
# HEDERA_LOCAL_MIRROR_NODE_ENDPOINT='http://127.0.0.1:5600'

# Hedera Previewnet
# HEDERA_PREVIEWNET_JSON_RPC_ENDPOINT='https://previewnet.hashio.io/api'
# HEDERA_PREVIEWNET_MIRROR_NODE_ENDPOINT='https://previewnet.mirrornode.hedera.com'

# Hedera Testnet (uncomment to use)
# HEDERA_TESTNET_JSON_RPC_ENDPOINT='https://testnet.hashio.io/api'
# HEDERA_TESTNET_MIRROR_NODE_ENDPOINT='https://testnet.mirrornode.hedera.com'

# Hedera Mainnet (uncomment to use)
# HEDERA_MAINNET_JSON_RPC_ENDPOINT='https://mainnet.hashio.io/api'
# HEDERA_MAINNET_MIRROR_NODE_ENDPOINT='https://mainnet.mirrornode.hedera.com'

# =============================================================================
# UPGRADE WORKFLOW CONFIGURATION
# =============================================================================
# Used by the upgrade CLI: npm run upgrade:testnet
# Only needed when upgrading an existing deployment.

# Required for upgrades: Address of the existing BusinessLogicResolver
# BLR_ADDRESS='0x0000000000000000000000000000000000000000'

# Optional: Comma-separated list of ResolverProxy token addresses to update
# Leave empty if you don't want to update existing tokens
# PROXY_ADDRESSES=''

# Optional: Which configurations to create: 'equity', 'bond', or 'both'
# CONFIGURATIONS='both'

# Optional: Include TimeTravel facet variants (for testing time-dependent features)
# USE_TIMETRAVEL=false

# Optional: Deploy facets in partial batches to avoid gas limits
# PARTIAL_BATCH_DEPLOY=true

# Optional: Number of facets to deploy per batch (network-dependent defaults)
# BATCH_SIZE=10

# =============================================================================
# TUP (Transparent Upgradeable Proxy) UPGRADE CONFIGURATION
# =============================================================================
# Used by the TUP upgrade CLI: npm run upgrade:tup:testnet
# Only needed when upgrading proxy implementations (BLR or Factory).

# Required for TUP upgrades: Address of the ProxyAdmin contract
# PROXY_ADMIN_ADDRESS='0x0000000000000000000000000000000000000000'

# Optional: Proxy addresses to upgrade (leave empty to skip)
# BLR_PROXY=''
# FACTORY_PROXY=''

# Optional: Deploy new implementations (true) or use existing addresses below (false)
# DEPLOY_NEW_BLR_IMPL=true
# DEPLOY_NEW_FACTORY_IMPL=true

# Optional: Existing implementation addresses (used when DEPLOY_NEW_*_IMPL=false)
# BLR_IMPLEMENTATION=''
# FACTORY_IMPLEMENTATION=''

# =============================================================================
# HARDHAT CONFIG
# =============================================================================
# Report contract sizes on compilation
CONTRACT_SIZER_RUN_ON_COMPILE=true

# Report gas usage in tests
REPORT_GAS=true
