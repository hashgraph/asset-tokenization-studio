# ATS SDK - Environment Variables (for running tests only)
#
# These variables are used by the SDK test suite to connect to a Hedera network
# and interact with deployed contracts. They are NOT required for building the SDK
# or running the web application.

# * Test Accounts (ECDSA)
# Two accounts are needed: one as deployer/admin, another as a secondary user.
# Private keys in RAW hex format (not DER encoded).

# Account 1 - Primary test account (deployer/admin)
CLIENT_PRIVATE_KEY_ECDSA_1=
CLIENT_PUBLIC_KEY_ECDSA_1=
CLIENT_EVM_ADDRESS_ECDSA_1=
CLIENT_ACCOUNT_ID_ECDSA_1=

# Account 2 - Secondary test account (used for transfers, permissions, etc.)
CLIENT_PRIVATE_KEY_ECDSA_2=
CLIENT_PUBLIC_KEY_ECDSA_2=
CLIENT_EVM_ADDRESS_ECDSA_2=
CLIENT_ACCOUNT_ID_ECDSA_2=

# * Deployed Contract Addresses
# Factory and Resolver addresses from a previous contract deployment.
# See packages/ats/contracts for deployment instructions.
FACTORY_ADDRESS=
RESOLVER_ADDRESS=

# * DFNS Custodial Wallet Configuration (Optional)
# Only needed when running tests for the DFNS transaction adapter.
DFNS_SERVICE_ACCOUNT_AUTHORIZATION_TOKEN=
DFNS_SERVICE_ACCOUNT_CREDENTIAL_ID=
DFNS_SERVICE_ACCOUNT_PRIVATE_KEY_OR_PATH=
DFNS_APP_ORIGIN=
DFNS_APP_ID=
DFNS_TEST_URL=
DFNS_WALLET_ID=
DFNS_WALLET_PUBLIC_KEY=
DFNS_HEDERA_ACCOUNT_ID=

# * Fireblocks Custodial Wallet Configuration (Optional)
# Only needed when running tests for the Fireblocks transaction adapter.
FIREBLOCKS_API_SECRET_KEY_PATH=
FIREBLOCKS_API_KEY=
FIREBLOCKS_BASE_URL=
FIREBLOCKS_ASSET_ID=
FIREBLOCKS_VAULT_ACCOUNT_ID=
FIREBLOCKS_HEDERA_ACCOUNT_ID=
FIREBLOCKS_HEDERA_PUBLIC_KEY=

# * AWS KMS Configuration (Optional)
# Only needed when running tests for the AWS KMS transaction adapter.
AWS_KMS_HEDERA_ACCOUNT_ID=''
AWS_KMS_HEDERA_PUBLIC_KEY=''
AWS_KMS_ACCESS_KEY_ID=''
AWS_KMS_SECRET_ACCESS_KEY=''
AWS_KMS_REGION=''
AWS_KMS_KEY_ID=''
